{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tusmo",
  "scopeName": "source.tusmo",
  "fileTypes": [
    "tus"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#entities"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tusmo",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.tusmo",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.double.tusmo",
          "begin": "\\$\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tusmo"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tusmo"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tusmo",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.tusmo",
              "begin": "\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.tusmo"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.tusmo"
                }
              },
              "patterns": [
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                },
                {
                  "include": "#keywords"
                },
                {
                  "include": "#types"
                },
                {
                  "include": "#builtins"
                },
                {
                  "include": "#operators"
                },
                {
                  "include": "#constants"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.triple.tusmo",
          "begin": "\"\"\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tusmo"
            }
          },
          "end": "\"\"\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tusmo"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tusmo",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.tusmo",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tusmo"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tusmo"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tusmo",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tusmo",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.char.begin.tusmo"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.char.end.tusmo"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tusmo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.tusmo",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.tusmo",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.tusmo",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.tusmo",
          "match": "\\b(haddii|ama_haddii|haddii_kale)\\b"
        },
        {
          "name": "keyword.control.loop.tusmo",
          "match": "\\b(inta|samay|soco|joog|kasoco|kasta|laga|bilaabo|ay|helo)\\b"
        },
        {
          "name": "keyword.control.flow.tusmo",
          "match": "\\b(soo_celi)\\b"
        },
        {
          "name": "keyword.other.import.tusmo",
          "match": "\\b(keen)\\b"
        },
        {
          "name": "keyword.declaration.tusmo",
          "match": "\\b(keyd|hawl|shaqo|koox|dhis|burbur|cusub)\\b"
        },
        {
          "name": "variable.language.self.tusmo",
          "match": "\\bkan\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.tusmo",
          "match": "\\b(tiro|jajab|eray|xaraf|miyaa|waxbo)\\b"
        },
        {
          "name": "storage.type.collection.tusmo",
          "match": "\\b(tix|qaamuus|tix_cayiman)\\b"
        },
        {
          "name": "entity.name.type.class.tusmo",
          "match": "(?<=:\\s*)(?:[A-Z][a-zA-Z0-9_]*)"
        },
        {
          "name": "entity.name.type.class.tusmo",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.tusmo",
          "match": "\\b(hel|qor|show|gali|nooc|dherer|tix_cayiman)\\b"
        },
        {
          "name": "support.function.ffi.tusmo",
          "match": "\\b___c__call_\\b"
        },
        {
          "name": "support.function.embedded-c.tusmo",
          "match": "\\b___c__code_\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.definition.variable.tusmo",
          "match": "\\bkeyd\\s*:[^=;\\n]+\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.other.definition.tusmo"
            }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.tusmo",
          "match": "\\b(run|haa|been|maya)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.tusmo",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.word.comparison.tusmo",
          "match": "\\b(lamid_maaha|lamid|weyn_lamid|yar_lamid|weyn|yar)\\b"
        },
        {
          "name": "keyword.operator.logical.tusmo",
          "match": "\\b(iyo|ama|ahayn)\\b|\\|\\||&&"
        },
        {
          "name": "keyword.operator.arithmetic.tusmo",
          "match": "\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.range.tusmo",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arrow.tusmo",
          "match": "=>"
        },
        {
          "name": "keyword.operator.assignment.tusmo",
          "match": "(?<![!<>=])=(?!=|>)"
        },
        {
          "name": "keyword.operator.ternary.tusmo",
          "match": "\\?|:"
        }
      ]
    },
    "entities": {
      "patterns": [
        {
          "name": "entity.name.type.class.tusmo",
          "match": "(?<=\\bkoox\\s+)[A-Z][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.function.tusmo",
          "match": "\\b(?!(?:haddii|ama_haddii|haddii_kale|inta|samay|soco|joog|kasoco|kasta|laga|bilaabo|ay|helo|keyd|hawl|shaqo|koox|dhaxlaya|dhis|burbur|cusub|hel|qor|show|gali|nooc|dherer|tix|qaamuus|tix_cayiman|tiro|jajab|eray|xaraf|miyaa|waxbo|run|haa|been|maya|keen|waalid|soo_celi|kan|ahayn|iyo|lamid|lamid_maaha|weyn|yar|weyn_lamid|yar_lamid|___c__call_|___c__code_)\\b)([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.tusmo"
            }
          }
        }
      ]
    }
  }
}
